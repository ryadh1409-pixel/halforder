STRIPE_SECRET_KEY=sk_live_or_sk_test_here
# Webhook signing secret from Stripe Dashboard → Developers → Webhooks (per endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...
# Checkout currency (ISO), default cad
STRIPE_CHECKOUT_CURRENCY=cad
# Platform fee percent (default 7)
STRIPE_PLATFORM_FEE_PERCENT=7
# After Connect onboarding, redirect back to your app or web dashboard
STRIPE_CONNECT_RETURN_URL=https://halforder.app/restaurant-dashboard
STRIPE_CONNECT_REFRESH_URL=https://halforder.app/restaurant-dashboard
# Optional comma-separated extra URL prefixes allowed for Checkout success/cancel (must match client)
# STRIPE_ALLOWED_REDIRECT_PREFIXES=https://your-staging.app,halforder://

GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password
ADMIN_FCM_TOKEN=optional_admin_token
