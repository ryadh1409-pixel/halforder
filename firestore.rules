    function isValidFoodShareInviteCreate() {
      return request.resource.data.keys().hasAll(['senderUid', 'adminFoodShareId', 'inviteLink', 'channel', 'createdAt'])
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.adminFoodShareId is string
        && request.resource.data.adminFoodShareId.size() > 0
        && request.resource.data.inviteLink is string
        && request.resource.data.inviteLink.size() > 0
        && request.resource.data.channel is string
        && (request.resource.data.channel == 'whatsapp' || request.resource.data.channel == 'share_sheet')
        && request.resource.data.createdAt == request.time
        && (!request.resource.data.keys().hasAny(['openedAt']) || request.resource.data.openedAt == null)
        && (!request.resource.data.keys().hasAny(['openedByUid']) || request.resource.data.openedByUid == null)
        && (!request.resource.data.keys().hasAny(['convertedAt']) || request.resource.data.convertedAt == null)
        && (!request.resource.data.keys().hasAny(['convertedMatchId']) || request.resource.data.convertedMatchId == null);
    }
    function isValidFoodShareInviteSenderPatch() {
      return resource.data.senderUid == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['inviteLink', 'channel'])
        && request.resource.data.senderUid == resource.data.senderUid
        && request.resource.data.adminFoodShareId == resource.data.adminFoodShareId
        && request.resource.data.inviteLink is string
        && request.resource.data.inviteLink.size() > 0
        && (request.resource.data.channel == 'whatsapp' || request.resource.data.channel == 'share_sheet');
    }
    function isValidFoodShareInviteOpen() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['openedAt', 'openedByUid'])
        && request.resource.data.openedByUid == request.auth.uid
        && request.resource.data.openedByUid is string
        && resource.data.openedAt == null
        && (!resource.data.keys().hasAny(['openedByUid']) || resource.data.openedByUid == null);
    }
    function isValidFoodShareInviteConvert() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['convertedAt', 'convertedMatchId'])
        && request.resource.data.convertedMatchId is string
        && request.resource.data.convertedMatchId.size() > 0
        && resource.data.convertedAt == null
        && (resource.data.senderUid == request.auth.uid || resource.data.openedByUid == request.auth.uid);
    }
    match /foodShareInvites/{inviteId} {
      allow get: if isAdmin()
        || (isSignedIn() && resource.data.senderUid == request.auth.uid)
        || (isSignedIn() && resource.data.openedByUid == request.auth.uid);
      allow list: if isAdmin();
      allow create: if isSignedIn()
        && !isCurrentUserRestricted()
        && isValidFoodShareInviteCreate();
      allow update: if isSignedIn()
        && (
          isValidFoodShareInviteSenderPatch()
          || isValidFoodShareInviteOpen()
          || isValidFoodShareInviteConvert()
        );
      allow delete: if false;
    }
    match /foodShares/{shareId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
    match /matches/{matchId} {
      /**
       * Pre-create existence check: second joiner does getDoc(matches/{id}) before setDoc.
       * Non-existent docs have no resource.data — allow get only when matchId embeds auth.uid
       * (format: {shareId}_{uidA}_{uidB}). Existing docs: participants only.
       */
      allow get: if isAdmin()
        || (
          isSignedIn()
          && (
            (
              !exists(/databases/$(database)/documents/matches/$(matchId))
              && matchId.matches('.*_' + request.auth.uid + '(_.*|$)')
            )
            || (
              exists(/databases/$(database)/documents/matches/$(matchId))
              && request.auth.uid in resource.data.users
            )
          )
        );
      allow list: if isAdmin()
        || (
          isSignedIn()
          && request.auth.uid in resource.data.users
        );
      allow create: if isValidFoodMatchCreate(matchId) || isValidAdminFoodShareMatchCreate(matchId);
      allow update: if isFoodShareMatchCancelUpdate();
      allow delete: if false;
    }
    match /matchChats/{chatId} {
      allow read: if isMatchChatParticipant(chatId);
      allow create: if isValidMatchChatCreate(chatId);
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.get('participantIds', [])
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['updatedAt']);
      allow delete: if false;
