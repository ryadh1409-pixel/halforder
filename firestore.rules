rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
    match /support_chats/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == 'REPLACE_WITH_ADMIN_UID' || request.auth.token.get('support', false) == true);
      allow write: if false;
    }
    match /support_chats/{userId}/messages/{messageId} {
      allow read, write: if request.auth != null
        && (userId == request.auth.uid || request.auth.uid == 'REPLACE_WITH_ADMIN_UID' || request.auth.token.get('support', false) == true);
    }
    match /blocks/{blockId} {
      allow create: if request.auth != null && request.resource.data.blockerId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.blockerId == request.auth.uid || resource.data.blockedId == request.auth.uid);
      allow update, delete: if false;
    }
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        (request.auth.uid in request.resource.data.get('participantUids', [])
        && !(request.auth.uid in resource.data.get('participantUids', []))
        && request.resource.data.get('participantUids', []).hasAll(resource.data.get('participantUids', []))
        && request.resource.data.get('participantUids', []).size() == resource.data.get('participantUids', []).size() + 1
        && request.resource.data.get('joinedCount', 0) == resource.data.get('joinedCount', 0) + 1)
        || (request.auth.uid in resource.data.get('participantUids', [])
        && request.resource.data.get('participantUids', []) == resource.data.get('participantUids', [])
        && request.resource.data.get('joinedCount', 0) == resource.data.get('joinedCount', 0))
      );
      allow delete: if false;

      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/orders/$(orderId)).data.get('participantUids', []);
      }

      match /ratings/{ratingId} {
        allow read, write: if request.auth != null
          && ratingId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/orders/$(orderId)).data.get('participantUids', []);
      }
    }
  }
}
