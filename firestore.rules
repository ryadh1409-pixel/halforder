        || (request.auth != null && hasDriverAccountDoc());
      allow list: if isAdmin();
      allow create: if isAdmin()
        || (request.auth != null && request.auth.uid == userId && request.resource.data.get('stripeOnboardingComplete', false) == false);
      allow update: if isAdmin()
        || (request.auth != null && request.auth.uid == userId
            && userStripeOnboardingCompleteNotForged()
            && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['halfOrderBalance', 'walletBalance']))
        || (
          request.auth != null
          && request.auth.uid == userId
          && userStripeOnboardingCompleteNotForged()
          && !request.resource.data.diff(resource.data).affectedKeys()
