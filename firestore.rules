          )
          || (
            !isCurrentUserRestricted()
            && isValidDriverLocationOnlyPatch()
          )
          || (
            !isCurrentUserRestricted()
            && isValidDriverActivePatch()
          )
          || (
            !isCurrentUserRestricted()
            && marketplaceOrderCancelPatchOk()
          )
          || restaurantDashboardPatchOk()
          || isSwipeAcceptUpdate()
          || isParticipantsJoinUpdate()
          || isParticipantsJoinWithExtrasUpdate()
          || isHalfOrderParticipantIncrementalJoin()
          || isHalfOrderParticipantBootstrapJoin()
          || isJoinedAtMapBackfillUpdate()
          || isParticipantsLeaveUpdate()
          || isOrderTypingUpdate()
          || isCreatorOnlyNonJoinUpdate()
          || isMarkOrderExpiredUpdate()
          || isHalfOrderCancelUpdate()
          || isHalfOrderMarkActiveUpdate()
          || isHalfOrderCompleteUpdate()
          || (
            !isCurrentUserRestricted()
            && canAccessMarketplaceDeliveryOrder(resource.data)
            && (
              !isMarketplaceDeliveryOrderDoc(resource.data)
              || marketplaceOrderActorPatchOk()
            )
          )
          || (
            !isCurrentUserRestricted()
            && marketplaceCustomerCheckoutPatchOk()
          )
        );
      allow delete: if isAdmin()
        || (
          isSignedIn()
          && primaryUidFromOrder(resource.data) == request.auth.uid
        );

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && (
            isAdmin()
            || (
              !isCurrentUserRestricted()
              && orderChatParticipantOk(
                get(/databases/$(database)/documents/orders/$(orderId)).data
              )
            )
          );
        allow create: if isSignedIn()
          && !isCurrentUserRestricted()
          && orderChatWritable(get(/databases/$(database)/documents/orders/$(orderId)).data)
          && (
            isAdmin()
            || orderChatParticipantOk(
              get(/databases/$(database)/documents/orders/$(orderId)).data
            )
          )
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.senderRole is string
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 600
          && request.resource.data.createdAt == request.time
          && request.resource.data.sentAt == request.time
          && (
            !request.resource.data.keys().hasAny(['chatType'])
            || (
              request.resource.data.chatType == 'customer_driver'
              || request.resource.data.chatType == 'restaurant_driver'
              || request.resource.data.chatType == 'support'
            )
          )
          && (
            !request.resource.data.keys().hasAny(['senderRole'])
            || (
              request.resource.data.senderRole is string
              && request.resource.data.senderRole.size() > 0
              && request.resource.data.senderRole.size() <= 24
            )
          );
        allow update: if isAdmin() || isOrderMessageStatusUpdate(orderId);
        allow delete: if false;
      }
    }
    match /food_cards/{cardId} {
      allow read, list: if isAdmin();
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isValidFoodCardOrderIdLink(cardId) || isValidFoodCardJoinUpdate();
    }
    match /foodTemplates/{templateId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.members is list
        && request.resource.data.members.size() == 1
        && request.resource.data.members[0] == request.auth.uid
        && request.resource.data.foodType is string
        && request.resource.data.maxSize == 4
        && request.resource.data.status == 'waiting'
        && request.resource.data.anchorLocation is map;
      allow update: if request.auth != null
        && (
          (resource.data.members is list && request.auth.uid in resource.data.members)
          || (
            resource.data.members is list
            && request.resource.data.members is list
            && request.resource.data.members.size() == resource.data.members.size() + 1
            && request.auth.uid in request.resource.data.members
            && resource.data.members.size() < 4
          )
        );
      allow delete: if request.auth != null && resource.data.members is list && request.auth.uid in resource.data.members;
    }
    match /carts/{cartId} {
      allow read, write: if request.auth != null;
    }
    function paymentDocOwnerUid(d) {
      return d.get('userId', d.get('uid', d.get('customerId', '')));
    }
    function paymentDocOwnerMatchesAuth(d) {
      return isSignedIn()
        && paymentDocOwnerUid(d) is string
        && paymentDocOwnerUid(d).size() > 0
        && paymentDocOwnerUid(d) == request.auth.uid;
    }
    match /payments/{paymentId} {
      allow create: if isSignedIn()
        && paymentDocOwnerMatchesAuth(request.resource.data);
      allow read: if isAdmin()
        || paymentDocOwnerMatchesAuth(resource.data);
      allow update: if isAdmin()
        || (
          paymentDocOwnerMatchesAuth(resource.data)
          && paymentDocOwnerUid(request.resource.data) == paymentDocOwnerUid(resource.data)
        );
      allow delete: if isAdmin()
        || paymentDocOwnerMatchesAuth(resource.data);
    }
    match /paymentTransactions/{paymentId} {
      allow read, list: if isAdmin();
      allow write: if false;
    }
    /**
     * Admin-only payment support notes + conversation history.
     * Separate from paymentTransactions (client writes denied there).
     */
    match /paymentAdminMeta/{paymentId} {
      allow read, create, update, delete: if isAdmin();
      match /messages/{messageId} {
        allow read, create, update, delete: if isAdmin();
      }
    }
    match /paymentAuditLogs/{logId} {
      allow read, list: if isAdmin();
      allow write: if false;
    }
    match /stripePayoutRecords/{payoutId} {
      allow read, list: if isAdmin();
      allow write: if false;
    }
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create, update, delete: if isAdmin()
        || (
          request.auth != null
          && request.auth.uid == restaurantId
          && requestUserIsRestaurant()
        );
      match /orders/{orderId} {
        allow read, write: if isAdmin()
          || (
            request.auth != null
            && request.auth.uid == restaurantId
            && requestUserIsRestaurant()
          );
      }
      match /{sub=**} {
        allow read: if true;
        allow write: if isAdmin()
          || (
            request.auth != null
            && request.auth.uid == restaurantId
            && requestUserIsRestaurant()
          );
      }
    }
    match /menuItems/{itemId} {
      allow read: if true;
      allow create, update, delete: if isAdmin()
        || (request.auth != null && request.resource.data.restaurantId is string && request.resource.data.restaurantId == request.auth.uid)
        || (request.auth != null && resource.data.restaurantId is string && resource.data.restaurantId == request.auth.uid);
    }
    /**
     * Denormalized unassigned delivery queue for drivers (synced by Cloud Function).
     * List queries use exists(drivers/{auth.uid}) only — no custom claims required.
     */
    match /driver_marketplace_pool/{orderId} {
      allow read, list: if isAdmin() || hasDriverAccountDoc();
      allow write: if false;
    }
    match /platformSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /homeBanners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    /** Best-effort admin inbox events from signed-in clients (create only). */
    match /alerts/{alertId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'type',
          'message',
          'createdAt',
          'status',
          'orderId',
          'hostId',
          'creatorId',
          'restaurantName'
        ])
        && request.resource.data.type is string
        && request.resource.data.type.size() > 0
        && request.resource.data.type.size() < 64
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() < 500
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt == request.time;
      allow update, delete: if isAdmin();
    }
    match /promoCodes/{promoId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    match /balanceLedger/{entryId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin();
      allow update, delete: if false;
    }
    match /drivers/{driverId} {
      allow read: if isAdmin()
        || (isSignedIn() && request.auth.uid == driverId)
        || (
          authTokenRoleIsRestaurant()
          && resource.data.isOnline == true
          && resource.data.get('adminSuspended', false) != true
        );
      allow create, delete: if isSignedIn()
        && request.auth.uid == driverId;
      allow update: if isAdmin()
        || (isSignedIn() && request.auth.uid == driverId);
    }
    match /app_sessions/{sessionId} {
      allow read, write: if request.auth != null;
    }
    match /notification_opens/{docId} {
      allow read, write: if request.auth != null;
    }
    match /live_locations/{orderId} {
      function liveLocOrderData() {
        return get(/databases/$(database)/documents/orders/$(orderId)).data;
      }
      function liveLocationDocKeysOk() {
        return request.resource.data.keys().hasOnly([
          'orderId',
          'driverId',
          'lat',
          'lng',
          'latitude',
          'longitude',
          'heading',
          'speed',
          'timestamp',
          'updatedAt',
        ]);
      }
      function liveLocationCoordsOk() {
        return request.resource.data.lat is number
          && request.resource.data.lng is number
          && request.resource.data.latitude is number
          && request.resource.data.longitude is number;
      }
      allow read: if isSignedIn()
        && !isCurrentUserRestricted()
        && canAccessMarketplaceDeliveryOrder(liveLocOrderData());
      allow create, update: if isSignedIn()
        && !isCurrentUserRestricted()
        && isDriver()
        && liveLocOrderData().get('deliveryType', '') == 'delivery'
        && driverAssignedToMarketplaceOrder(liveLocOrderData())
        && request.resource.data.orderId == orderId
        && request.resource.data.driverId == request.auth.uid
        && liveLocationCoordsOk()
        && liveLocationDocKeysOk()
        && driverLocationOptionalNumber(request.resource.data, 'heading')
        && driverLocationOptionalNumber(request.resource.data, 'speed');
      // Assigned driver live GPS mirror (orders/{id}.driverLocation batch companion).
      allow create, update: if isSignedIn()
        && request.auth.uid == liveLocOrderData().assignedDriverId
        && request.resource.data.orderId == orderId
        && request.resource.data.driverId == request.auth.uid
        && liveLocationCoordsOk()
        && liveLocationDocKeysOk();
      allow delete: if false;
    }
    /**
     * Optional driver dispatch queue documents (HalfOrder / OurFood).
     * Drivers and admins only; aligns with client delivery-layer expectations.
     */
    match /deliveryQueue/{docId} {
      allow read, write: if isSignedIn()
        && !isCurrentUserRestricted()
        && (isAdmin() || requestUserIsDriver());
    }
    /**
     * Emo AI executive reports (daily/weekly/monthly).
     * Admin-only; generated by admin clients or scheduled Cloud Functions.
     */
    match /emoAiReports/{reportId} {
      allow read, create, update, delete: if isAdmin();
    }

    /** Emo AI chat archive — users write own thread; admins read all. */
    match /emoAiConversations/{userId} {
      allow read: if isAdmin()
        || (isSignedIn() && request.auth.uid == userId);
      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /adminSupportThreads/{userId} {
      allow read: if isSignedIn()
        && (isAdmin() || request.auth.uid == userId);
      allow create: if isSignedIn()
        && !isCurrentUserRestricted()
        && (
          isAdmin()
          || (
            request.auth.uid == userId
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.lastMessage is string
            && request.resource.data.lastMessage.size() > 0
            && request.resource.data.lastMessage.size() <= 4000
            && request.resource.data.lastSender == 'user'
            && request.resource.data.archived == false
          )
        );
      allow update: if isSignedIn()
        && !isCurrentUserRestricted()
        && (
          isAdmin()
          || (
            request.auth.uid == userId
            && resource.data.userId == request.auth.uid
            && request.resource.data.userId == resource.data.userId
            && request.resource.data.lastSender == 'user'
            && request.resource.data.lastMessage is string
            && request.resource.data.lastMessage.size() > 0
            && request.resource.data.lastMessage.size() <= 4000
          )
        );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && (isAdmin() || request.auth.uid == userId);
        allow create: if isSignedIn()
          && !isCurrentUserRestricted()
          && (
            isAdmin()
            || (
              request.auth.uid == userId
              && request.resource.data.sender == 'user'
              && request.resource.data.senderUid == request.auth.uid
              && request.resource.data.body is string
              && request.resource.data.body.size() > 0
              && request.resource.data.body.size() <= 4000
            )
          );
        allow update, delete: if isAdmin();
      }
    }

    /**
     * Order Support tickets (Emo AI intake → HalfOrder Team).
     * Messages: supportTickets/{ticketId}/messages/{messageId}
     * sender is only "user" | "halforder_team" (never expose admin identity).
     */
    match /supportTickets/{ticketId} {
      allow read: if isSignedIn()
        && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
        && !isCurrentUserRestricted()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.orderId is string
        && request.resource.data.orderId.size() > 0
        && request.resource.data.type in ['food_complaint', 'delivery_complaint']
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 4000
        && request.resource.data.status == 'open';
      allow update: if isSignedIn()
        && !isCurrentUserRestricted()
        && (
          isAdmin()
          || (
            resource.data.userId == request.auth.uid
            && request.resource.data.userId == resource.data.userId
            && request.resource.data.orderId == resource.data.orderId
            && request.resource.data.type == resource.data.type
          )
        );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && (
            isAdmin()
            || get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.userId
              == request.auth.uid
          );
        allow create: if isSignedIn()
          && !isCurrentUserRestricted()
          && (
            (
              isAdmin()
              && request.resource.data.sender == 'halforder_team'
              && request.resource.data.text is string
              && request.resource.data.text.size() > 0
              && request.resource.data.text.size() <= 4000
            )
            || (
              get(/databases/$(database)/documents/supportTickets/$(ticketId)).data.userId
                == request.auth.uid
              && (
                request.resource.data.sender == 'user'
                || (
                  request.resource.data.sender == 'halforder_team'
                  && request.resource.data.persona == 'emo'
                )
              )
              && request.resource.data.text is string
              && request.resource.data.text.size() > 0
              && request.resource.data.text.size() <= 4000
            )
          );
        allow update, delete: if isAdmin();
      }
    }

    /**
     * CamelCase admin notifications for support tickets (client-created).
     * Distinct from legacy admin_notifications.
     */
    match /adminNotifications/{notificationId} {
      allow create: if isSignedIn()
        && !isCurrentUserRestricted()
        && request.resource.data.title is string
        && request.resource.data.message is string
        && request.resource.data.kind is string
        && request.resource.data.sentToCount == 0
        && request.resource.data.createdAt != null;
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    /**
     * Customer support conversations (Uber-style).
     * Doc id = customer uid. Messages append-only in subcollection.
     */
    match /supportConversations/{conversationId} {
      allow read: if isSignedIn()
        && (isAdmin() || request.auth.uid == conversationId);
      allow create: if isSignedIn()
        && !isCurrentUserRestricted()
        && (
          isAdmin()
          || (
            request.auth.uid == conversationId
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.lastMessage is string
            && request.resource.data.lastMessage.size() > 0
            && request.resource.data.lastMessage.size() <= 4000
          )
        );
      allow update: if isSignedIn()
        && !isCurrentUserRestricted()
        && (
          isAdmin()
          || request.auth.uid == conversationId
        );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && (isAdmin() || request.auth.uid == conversationId);
        allow create: if isSignedIn()
          && !isCurrentUserRestricted()
          && (
            isAdmin()
            || (
              request.auth.uid == conversationId
              && request.resource.data.sender == 'customer'
              && request.resource.data.senderUid == request.auth.uid
              && request.resource.data.body is string
              && request.resource.data.body.size() > 0
              && request.resource.data.body.size() <= 4000
            )
          );
        allow update, delete: if isAdmin();
      }
    }

    /** App-wide config (onboarding slides / display mode). */
    match /appConfig/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /** Admin push campaign history / delivery tracking. */
    match /pushCampaigns/{campaignId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
// force redeploy Thu May 28 03:06:57 EDT 2026
