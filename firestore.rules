    }
    match /matchQueues/{cardId} {
      allow read: if isSignedIn();
      allow create, update: if isValidMatchQueueWrite(cardId);
      allow delete: if false;
    }
    match /matchRequests/{requestId} {
      allow get, read: if canReadMatchRequestDoc(requestId);
