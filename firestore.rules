rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    /** `users/{uid}.role` — checked after email/uid allowlist (no get when already admin). */
    function roleIsAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }
    function adminDocIsAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.get('active', false) == true;
    }
    function isAdminEmailToken() {
      return isSignedIn()
        && request.auth.token.email is string
        && (
          request.auth.token.email.lower() == 'ryadh1409@gmail.com'
          || request.auth.token.email.lower() == 'admin@ourfood.com'
          || request.auth.token.email.lower() == 'support@halforder.app'
        );
    }
    function isAdminUidAllowlist() {
      return isSignedIn()
        && (
          request.auth.uid == 'KT3LfXRsVgaH4LfRTQaexvj3CRn1'
          || request.auth.uid == 'Gjj6x4OU4OQmsnplollo9PLLpxt2'
        );
    }
    function isAdmin() {
      return isAdminEmailToken()
        || isAdminUidAllowlist()
        || roleIsAdmin()
        || adminDocIsAdmin();
    }
    function userStripeOnboardingCompleteNotForged() {
      return !(request.resource.data.get('stripeOnboardingComplete', false) == true
        && resource.data.get('stripeOnboardingComplete', false) != true);
    }
    function userProfileExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    /** Avoid rule failure when `users/{uid}` is not provisioned yet (auth without Firestore profile). */
    function isCurrentUserRestricted() {
      return isSignedIn()
        && userProfileExists()
        && (
          currentUserData().get('banned', false) == true
          || currentUserData().get('restricted', false) == true
          || currentUserData().get('suspended', false) == true
        );
    }
    function isNewUserForOrderLimits() {
      return userProfileExists()
        && currentUserData().get('totalOrdersCompleted', 0) is int
        && currentUserData().get('totalOrdersCompleted', 0) <= 3;
    }
    function canCreateOrderBySafetyLimits() {
      return !isCurrentUserRestricted()
        && (
          !userProfileExists()
          || !isNewUserForOrderLimits()
          || currentUserData().get('activeOrderCount', 0) < 1
        );
    }
    /** Owner uid must match auth (baseline for all customer order creates). */
    function ordersCreateOwnerMatchesAuth() {
      return request.auth != null
        && request.resource.data.userId is string
        && request.resource.data.userId == request.auth.uid;
    }
    /** Customer read: owner, assigned restaurant uid, or assigned driver uid. */
    function ordersReadByParticipant() {
      return request.auth != null
        && (
          resource.data.userId == request.auth.uid
          || isRestaurantVendorActor(resource.data)
          || resource.data.driverId == request.auth.uid
          || resource.data.get('assignedDriverId', '') == request.auth.uid
        );
    }
    /** Role from Auth custom claims (query-safe; set by refreshUserRoleClaims). */
    function authTokenRoleIsDriver() {
      return isSignedIn()
        && (
          request.auth.token.role == 'driver'
          || request.auth.token.get('role', '') == 'driver'
        );
    }
    /** Driver account doc (query-safe membership check for pool collection). */
    function hasDriverAccountDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/drivers/$(request.auth.uid));
    }
    function authTokenRoleIsRestaurant() {
      return isSignedIn()
        && (
          request.auth.token.role == 'restaurant'
          || request.auth.token.role == 'host'
          || request.auth.token.get('role', '') == 'restaurant'
          || request.auth.token.get('role', '') == 'host'
        );
    }
    /**
     * Unassigned marketplace delivery pool — must mirror subscribeDriverQueue filters exactly.
     * Uses Auth custom claim role=driver only (no get/exists) so collection listeners work.
     */
  /** Canonical + legacy courier statuses visible on driver marketplace. */
    function marketplacePoolDeliveryStatusOk(ds) {
      return ds == 'pending'
        || ds == 'accepted'
        || ds == 'preparing'
        || ds == 'ready_for_pickup'
        || ds == 'waiting_driver'
        || ds == 'ready'
        || ds == 'accepted_for_delivery'
        || ds == 'pending_driver';
    }
    function marketplaceOrderPaidOk(d) {
      let ps = d.get('paymentStatus', '');
      let psLower = ps is string ? ps.lower() : '';
      return psLower == 'paid' || psLower == 'succeeded' || psLower == 'complete';
    }
    function marketplaceOrderNotTerminalForClaim(d) {
      let status = d.get('status', '');
      let ds = d.get('deliveryStatus', '');
      return status != 'cancelled'
        && status != 'rejected'
        && ds != 'cancelled'
        && ds != 'delivered';
    }
    function driverMarketplacePoolReadable() {
      return authTokenRoleIsDriver()
        && resource.data.deliveryType == 'delivery'
        && marketplaceOrderPaidOk(resource.data)
        && resource.data.get('expired', false) != true
        && resource.data.get('marketplaceArchived', false) != true
        && marketplacePoolDeliveryStatusOk(resource.data.get('deliveryStatus', ''))
        && resource.data.driverId == null
        && resource.data.assignedDriverId == null;
    }
    /** Single-doc read on unassigned pool orders (accept flow / getDoc). */
    function driverPoolOrderSingleRead() {
      return hasDriverAccountDoc()
        && resource.data.deliveryType == 'delivery'
        && marketplaceOrderPaidOk(resource.data)
        && marketplacePoolDeliveryStatusOk(resource.data.get('deliveryStatus', ''))
        && resource.data.driverId == null
        && resource.data.assignedDriverId == null;
    }
    /** Driver earnings / delivered-stats list — mirrors subscribeDriverEarnings filters. */
    function driverEarningsOrderListReadable() {
      return hasDriverAccountDoc()
        && resource.data.get('deliveryType', 'delivery') == 'delivery'
        && (
          resource.data.driverId == request.auth.uid
          || resource.data.get('assignedDriverId', '') == request.auth.uid
        )
        && (
          resource.data.get('earningsRecorded', false) == true
          || resource.data.status == 'delivered'
          || resource.data.status == 'completed'
          || resource.data.get('deliveryStatus', '') == 'delivered'
        );
    }
    /** @deprecated Use driverEarningsOrderListReadable */
    function driverDeliveredStatsListReadable() {
      return driverEarningsOrderListReadable();
    }
    /** Driver active/assigned orders by driverId — mirrors subscribeToDriverOrders. */
    function driverOrdersByDriverIdListReadable() {
      return hasDriverAccountDoc()
        && resource.data.driverId == request.auth.uid
        && resource.data.deliveryType == 'delivery';
    }
    /** Driver active/assigned orders by assignedDriverId. */
    function driverOrdersByAssignedDriverIdListReadable() {
      return hasDriverAccountDoc()
        && resource.data.get('assignedDriverId', '') == request.auth.uid
        && resource.data.deliveryType == 'delivery';
    }
    function requestUserRoleRaw() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '')
        : '';
    }
    /**
     * Marketplace checkout (`restaurant-menu` cart → `orders/`).
     * Not subject to HalfOrder `activeOrderCount` limits (unpaid checkout may retry).
     */
    function requestUserIsCustomer() {
      return requestUserRoleRaw() == 'user'
        || requestUserRoleRaw() == 'customer';
    }
    /**
     * Marketplace checkout: owner uid must match auth.
     * Allows customer + restaurant/host (e.g. owner testing checkout); blocks drivers only.
     */
    function requestUserRoleAllowsMarketplaceCheckout() {
      let r = requestUserRoleRaw();
      return r != 'driver'
        && (
          r == 'user'
          || r == 'customer'
          || r == ''
          || r == 'restaurant'
          || r == 'host'
          || r == 'admin'
        );
    }
    function requestUserIsRestaurant() {
      return requestUserRoleRaw() == 'restaurant'
        || requestUserRoleRaw() == 'host';
    }
    function requestUserIsDriver() {
      return requestUserRoleRaw() == 'driver';
    }
    function isValidMarketplaceOrderCreate() {
      return ordersCreateOwnerMatchesAuth()
        && requestUserRoleAllowsMarketplaceCheckout()
        && !isCurrentUserRestricted()
        && request.resource.data.restaurantId is string
        && request.resource.data.restaurantId.size() > 0
        && request.resource.data.venueId is string
        && request.resource.data.venueId.size() > 0
        && request.resource.data.status == 'awaiting_payment'
        && request.resource.data.paymentStatus == 'unpaid'
        && (
          request.resource.data.deliveryType == 'delivery'
          || request.resource.data.deliveryType == 'pickup'
        )
        && (
          request.resource.data.deliveryType != 'delivery'
          || (
            request.resource.data.deliveryEligible == true
            && request.resource.data.deliveryDistanceKm is number
            && request.resource.data.deliveryDistanceKm >= 0
            && request.resource.data.deliveryDistanceKm <= request.resource.data.maxDeliveryDistanceKmAtCheckout
            && request.resource.data.maxDeliveryDistanceKmAtCheckout is number
            && request.resource.data.maxDeliveryDistanceKmAtCheckout > 0
          )
        )
        && (
          !request.resource.data.keys().hasAny(['createdAt'])
          || request.resource.data.createdAt == request.time
        )
        && (
          !request.resource.data.keys().hasAny(['customerId'])
          || request.resource.data.customerId == request.auth.uid
        );
    }
    /** Customer owns a marketplace order (read / limited update). */
    function isMarketplaceOrderCustomer(d) {
      return isSignedIn()
        && d.userId is string
        && d.userId == request.auth.uid;
    }
    function isMarketplaceOrderOwner(d) {
      return isSignedIn()
        && d.userId is string
        && d.userId == request.auth.uid;
    }
    function listAllStrings(lst) {
      return lst is list
        && lst.size() <= 20
        && (lst.size() < 1 || lst[0] is string)
        && (lst.size() < 2 || lst[1] is string)
        && (lst.size() < 3 || lst[2] is string)
        && (lst.size() < 4 || lst[3] is string)
        && (lst.size() < 5 || lst[4] is string)
        && (lst.size() < 6 || lst[5] is string)
        && (lst.size() < 7 || lst[6] is string)
        && (lst.size() < 8 || lst[7] is string)
        && (lst.size() < 9 || lst[8] is string)
        && (lst.size() < 10 || lst[9] is string)
        && (lst.size() < 11 || lst[10] is string)
        && (lst.size() < 12 || lst[11] is string)
        && (lst.size() < 13 || lst[12] is string)
        && (lst.size() < 14 || lst[13] is string)
        && (lst.size() < 15 || lst[14] is string)
        && (lst.size() < 16 || lst[15] is string)
        && (lst.size() < 17 || lst[16] is string)
        && (lst.size() < 18 || lst[17] is string)
        && (lst.size() < 19 || lst[18] is string)
        && (lst.size() < 20 || lst[19] is string);
    }
    function participantsAllStrings(participants) {
      return listAllStrings(participants);
    }
    function usersAllStrings(users) {
      return listAllStrings(users);
    }
    function participantEntryMatchesUid(parts, uid, i) {
      return parts.size() > i
        && (
          (parts[i] is string && parts[i] == uid)
          || (
            parts[i] is map
            && parts[i].keys().hasAll(['userId', 'name'])
            && parts[i].userId == uid
          )
        );
    }
    function participantListContainsUid(parts, uid) {
      return participantEntryMatchesUid(parts, uid, 0)
        || participantEntryMatchesUid(parts, uid, 1)
        || participantEntryMatchesUid(parts, uid, 2)
        || participantEntryMatchesUid(parts, uid, 3)
        || participantEntryMatchesUid(parts, uid, 4)
        || participantEntryMatchesUid(parts, uid, 5)
        || participantEntryMatchesUid(parts, uid, 6)
        || participantEntryMatchesUid(parts, uid, 7)
        || participantEntryMatchesUid(parts, uid, 8)
        || participantEntryMatchesUid(parts, uid, 9)
        || participantEntryMatchesUid(parts, uid, 10)
        || participantEntryMatchesUid(parts, uid, 11)
        || participantEntryMatchesUid(parts, uid, 12)
        || participantEntryMatchesUid(parts, uid, 13)
        || participantEntryMatchesUid(parts, uid, 14)
        || participantEntryMatchesUid(parts, uid, 15)
        || participantEntryMatchesUid(parts, uid, 16)
        || participantEntryMatchesUid(parts, uid, 17)
        || participantEntryMatchesUid(parts, uid, 18)
        || participantEntryMatchesUid(parts, uid, 19);
    }
    function isOrderMember(orderData) {
      return isSignedIn()
        && (
          request.auth.uid in orderData.get('users', [])
          || participantListContainsUid(orderData.get('participants', []), request.auth.uid)
        );
    }
    function validOrderHostDoc(h) {
      return h is map
        && h.keys().hasAll(['userId', 'name'])
        && h.userId is string
        && h.name is string
        && h.userId.size() > 0;
    }
    function validParticipantDoc(p) {
      return p is map
        && p.keys().hasAll(['userId', 'name'])
        && p.userId is string
        && p.name is string
        && p.userId.size() > 0;
    }
    function allParticipantDocsValid(parts) {
      return parts is list
        && parts.size() <= 20
        && (parts.size() < 1 || validParticipantDoc(parts[0]))
        && (parts.size() < 2 || validParticipantDoc(parts[1]))
        && (parts.size() < 3 || validParticipantDoc(parts[2]))
        && (parts.size() < 4 || validParticipantDoc(parts[3]))
        && (parts.size() < 5 || validParticipantDoc(parts[4]))
        && (parts.size() < 6 || validParticipantDoc(parts[5]))
        && (parts.size() < 7 || validParticipantDoc(parts[6]))
        && (parts.size() < 8 || validParticipantDoc(parts[7]))
        && (parts.size() < 9 || validParticipantDoc(parts[8]))
        && (parts.size() < 10 || validParticipantDoc(parts[9]))
        && (parts.size() < 11 || validParticipantDoc(parts[10]))
        && (parts.size() < 12 || validParticipantDoc(parts[11]))
        && (parts.size() < 13 || validParticipantDoc(parts[12]))
        && (parts.size() < 14 || validParticipantDoc(parts[13]))
        && (parts.size() < 15 || validParticipantDoc(parts[14]))
        && (parts.size() < 16 || validParticipantDoc(parts[15]))
        && (parts.size() < 17 || validParticipantDoc(parts[16]))
        && (parts.size() < 18 || validParticipantDoc(parts[17]))
        && (parts.size() < 19 || validParticipantDoc(parts[18]))
        && (parts.size() < 20 || validParticipantDoc(parts[19]));
    }
    function countParticipantUserId(parts, uid) {
      return (parts.size() > 0 && parts[0] is map && parts[0].userId == uid ? 1 : 0)
        + (parts.size() > 1 && parts[1] is map && parts[1].userId == uid ? 1 : 0)
        + (parts.size() > 2 && parts[2] is map && parts[2].userId == uid ? 1 : 0)
        + (parts.size() > 3 && parts[3] is map && parts[3].userId == uid ? 1 : 0)
        + (parts.size() > 4 && parts[4] is map && parts[4].userId == uid ? 1 : 0)
        + (parts.size() > 5 && parts[5] is map && parts[5].userId == uid ? 1 : 0)
        + (parts.size() > 6 && parts[6] is map && parts[6].userId == uid ? 1 : 0)
        + (parts.size() > 7 && parts[7] is map && parts[7].userId == uid ? 1 : 0)
        + (parts.size() > 8 && parts[8] is map && parts[8].userId == uid ? 1 : 0)
        + (parts.size() > 9 && parts[9] is map && parts[9].userId == uid ? 1 : 0)
        + (parts.size() > 10 && parts[10] is map && parts[10].userId == uid ? 1 : 0)
        + (parts.size() > 11 && parts[11] is map && parts[11].userId == uid ? 1 : 0)
        + (parts.size() > 12 && parts[12] is map && parts[12].userId == uid ? 1 : 0)
        + (parts.size() > 13 && parts[13] is map && parts[13].userId == uid ? 1 : 0)
        + (parts.size() > 14 && parts[14] is map && parts[14].userId == uid ? 1 : 0)
        + (parts.size() > 15 && parts[15] is map && parts[15].userId == uid ? 1 : 0)
        + (parts.size() > 16 && parts[16] is map && parts[16].userId == uid ? 1 : 0)
        + (parts.size() > 17 && parts[17] is map && parts[17].userId == uid ? 1 : 0)
        + (parts.size() > 18 && parts[18] is map && parts[18].userId == uid ? 1 : 0)
        + (parts.size() > 19 && parts[19] is map && parts[19].userId == uid ? 1 : 0);
    }
    function isValidHalfOrderCreate() {
      return isSignedIn()
        && canCreateOrderBySafetyLimits()
        && !isCurrentUserRestricted()
        && request.resource.data.cardId is string
        && request.resource.data.cardId.size() > 0
        && request.resource.data.users is list
        && request.resource.data.users.size() == 1
        && usersAllStrings(request.resource.data.users)
        && request.auth.uid == request.resource.data.users[0]
        && request.resource.data.host is map
        && validOrderHostDoc(request.resource.data.host)
        && request.resource.data.host.userId == request.auth.uid
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 1
        && participantsAllStrings(request.resource.data.participants)
        && request.resource.data.participants[0] == request.auth.uid
        && request.resource.data.joinedAtMap is map
        && request.resource.data.joinedAtMap[request.auth.uid] is timestamp
        && (
          request.resource.data.status == 'waiting'
          || request.resource.data.status == 'active'
        )
        && (
          !request.resource.data.keys().hasAny(['matchWaitDeadlineAt'])
          || request.resource.data.matchWaitDeadlineAt is int
        )
        && request.resource.data.maxUsers is int
        && request.resource.data.maxUsers >= 2
        && request.resource.data.maxUsers <= 20
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.createdAt != null;
    }
    function isHalfOrderParticipantIncrementalJoin() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && resource.data.cardId is string
        && resource.data.get('users', []).size() > 0
        && request.resource.data.users is list
        && usersAllStrings(request.resource.data.users)
        && request.resource.data.participants is list
        && participantsAllStrings(request.resource.data.participants)
        && request.resource.data.participants.size() == request.resource.data.users.size()
        && request.resource.data.users.size() == resource.data.get('users', []).size() + 1
        && request.resource.data.participants.size() == resource.data.get('participants', []).size() + 1
        && request.auth.uid in request.resource.data.users
        && !(request.auth.uid in resource.data.get('users', []))
        && participantListContainsUid(request.resource.data.participants, request.auth.uid)
        && !participantListContainsUid(resource.data.get('participants', []), request.auth.uid)
        && request.resource.data.joinedAtMap is map
        && request.resource.data.joinedAtMap[request.auth.uid] is timestamp
        && request.resource.data.users.size() <= resource.data.get('maxUsers', 2)
        && request.resource.data.cardId == resource.data.cardId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.get('hostId', '') == resource.data.get('hostId', '')
        && request.resource.data.maxUsers == resource.data.maxUsers
        && (!resource.data.keys().hasAny(['host']) || request.resource.data.host == resource.data.host)
        && (
          (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['users', 'participants', 'joinedAtMap'])
            && request.resource.data.status == resource.data.status
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['users', 'participants', 'joinedAtMap', 'status'])
            && request.resource.data.status == 'matched'
            && (resource.data.status == 'waiting' || resource.data.status == 'active')
          )
        );
    }
    function isHalfOrderParticipantBootstrapJoin() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && resource.data.cardId is string
        && resource.data.get('participants', []).size() == 0
        && resource.data.get('users', []).size() == 1
        && request.resource.data.users is list
        && request.resource.data.users.size() == 2
        && usersAllStrings(request.resource.data.users)
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && participantsAllStrings(request.resource.data.participants)
        && request.auth.uid in request.resource.data.users
        && !(request.auth.uid in resource.data.get('users', []))
        && request.resource.data.participants[0] == resource.data.users[0]
        && request.resource.data.participants[1] == request.auth.uid
        && validOrderHostDoc(request.resource.data.host)
        && request.resource.data.host.userId == resource.data.users[0]
        && request.resource.data.joinedAtMap is map
        && request.resource.data.joinedAtMap[request.auth.uid] is timestamp
        && request.resource.data.cardId == resource.data.cardId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.get('hostId', '') == resource.data.get('hostId', '')
        && request.resource.data.maxUsers == resource.data.maxUsers
        && (
          (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['users', 'participants', 'host', 'joinedAtMap'])
            && request.resource.data.status == resource.data.status
          )
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['users', 'participants', 'host', 'joinedAtMap', 'status'])
            && request.resource.data.status == 'matched'
            && (resource.data.status == 'waiting' || resource.data.status == 'active')
          )
        );
    }
    function isHalfOrderCancelUpdate() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && resource.data.cardId is string
        && resource.data.cardId.size() > 0
        && (resource.data.status == 'waiting' || resource.data.status == 'matched' || resource.data.status == 'active')
        && request.resource.data.status == 'cancelled'
        && request.auth.uid in resource.data.get('users', [])
        && request.resource.data.cancelledBy == request.auth.uid
        && request.resource.data.users == resource.data.users
        && request.resource.data.cardId == resource.data.cardId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.get('hostId', '') == resource.data.get('hostId', '')
        && request.resource.data.maxUsers == resource.data.maxUsers
        && request.resource.data.participants == resource.data.participants
        && (!resource.data.keys().hasAny(['host']) || request.resource.data.host == resource.data.host)
        && request.resource.data.cancelledAt != null
        && (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'cancelledBy', 'cancelledAt'])
          || request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'cancelledBy', 'cancelledAt', 'cancelReason'])
        )
        && (!request.resource.data.keys().hasAny(['cancelReason']) || request.resource.data.cancelReason is string);
    }
    function isHalfOrderMarkActiveUpdate() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && resource.data.cardId is string
        && resource.data.cardId.size() > 0
        && resource.data.status == 'matched'
        && request.resource.data.status == 'active'
        && request.auth.uid in resource.data.get('users', [])
        && request.resource.data.users == resource.data.users
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.cardId == resource.data.cardId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.get('hostId', '') == resource.data.get('hostId', '')
        && request.resource.data.maxUsers == resource.data.maxUsers
        && (!resource.data.keys().hasAny(['host']) || request.resource.data.host == resource.data.host)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status']);
    }
    function isHalfOrderCompleteUpdate() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && resource.data.cardId is string
        && resource.data.cardId.size() > 0
        && (resource.data.status == 'matched' || resource.data.status == 'active')
        && request.resource.data.status == 'completed'
        && request.auth.uid in resource.data.get('users', [])
