            resource.data.get('deliveredAt', null) == null
            && request.resource.data.deliveredAt != null
          )
        )
        && (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(['readAt'])
          || (
            resource.data.get('readAt', null) == null
            && request.resource.data.readAt != null
          )
