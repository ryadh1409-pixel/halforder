        || (isSignedIn() && chatId.matches('venue-.*'))
        || (
          isSignedIn()
          && !isCurrentUserRestricted()
          && request.resource.data.orderId == chatId
          && request.resource.data.users is list
          && request.resource.data.users.size() >= 1
          && usersAllStrings(request.resource.data.users)
          && request.auth.uid in request.resource.data.users
          && request.resource.data.createdAt != null
        );
      allow update: if isAdmin()
        || isChatUsersAppendUpdate(chatId)
        || isChatLastMessagePatch(chatId)
        || isChatReadsUpdate(chatId)
        || (isSignedIn() && chatId.matches('venue-.*'));
      allow delete: if isAdmin();
      match /messages/{messageId} {
        allow read: if isAdmin()
          || isChatDocMember(chatId)
          || (isSignedIn() && chatId.matches('venue-.*'));
        allow create: if isAdmin()
          || (isSignedIn() && chatId.matches('venue-.*'))
          || (
            isSignedIn()
            && request.resource.data.text is string
            && request.resource.data.createdAt != null
            && (
              request.resource.data.senderId == 'system'
              || request.resource.data.sender == 'ai'
              || (request.resource.data.senderId == request.auth.uid && isChatDocMember(chatId))
            )
          );
        allow update, delete: if isAdmin();
      }
    }
    match /messages/{messageId} {
      allow read: if isAdmin()
        || (request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data.participants);
      allow create: if isAdmin()
        || (
          request.auth != null
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(request.resource.data.chatId)).data.participants
        );
      allow update, delete: if isAdmin();
    }
    match /calls/{callId} {
      allow create: if request.auth != null && request.resource.data.callerId == request.auth.uid;
      allow read, update: if request.auth != null && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow delete: if false;
    }
    match /complaints/{complaintId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }
    match /admins/{adminId} {
      allow read, write: if false;
    }
    match /notifications/{notificationId} {
      allow create, read: if request.auth != null;
      allow update, delete: if false;
    }
    match /notification_logs/{logId} {
      allow create, read: if request.auth != null;
      allow update, delete: if false;
    }
    match /user_activity/{activityId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }
    match /broadcasts/{broadcastId} {
      allow create, read: if isAdmin();
      allow update, delete: if false;
    }
    match /admin_notifications/{notificationId} {
      allow create: if isAdmin()
        && request.resource.data.title is string
        && request.resource.data.message is string
        && request.resource.data.sentToCount is int
        && request.resource.data.sentToCount >= 0
        && request.resource.data.createdAt == request.time;
      allow read: if isAdmin();
      allow update, delete: if false;
    }
    match /blocks/{blockId} {
      allow create: if request.auth != null && request.resource.data.blockerId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.blockerId == request.auth.uid || resource.data.blockedUserId == request.auth.uid);
      allow update: if false;
      allow delete: if request.auth != null && (resource.data.blockerId == request.auth.uid || resource.data.blockedUserId == request.auth.uid);
    }
    match /matches/{matchId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;
      allow create: if isValidFoodMatchCreate(matchId);
      allow update, delete: if false;
    }
    /** Internal Stripe webhook idempotency — Admin SDK only (clients denied). */
    match /stripe_processed_events/{stripeEventId} {
      allow read, write: if false;
    }
    /** Primary customer/creator uid across marketplace + legacy group-order schemas. */
    function primaryUidFromOrder(d) {
      return d.get('userId', '') is string && d.get('userId', '').size() > 0
        ? d.get('userId', '')
        : d.get('customerId', '') is string && d.get('customerId', '').size() > 0
          ? d.get('customerId', '')
          : d.get('creatorId', '') is string && d.get('creatorId', '').size() > 0
            ? d.get('creatorId', '')
            : d.users is list && d.users.size() > 0 && d.users[0] is string
              ? d.users[0]
              : '';
    }
    function driverAssignedToMarketplaceOrder(d) {
      return (d.driverId is string && d.driverId == request.auth.uid)
        || (
          d.get('assignedDriverId', '') is string
          && d.get('assignedDriverId', '') == request.auth.uid
        );
    }
    function noDriverAssignedYet(d) {
      return !(d.driverId is string && d.driverId.size() > 0)
        && !(d.get('assignedDriverId', '') is string && d.get('assignedDriverId', '').size() > 0);
    }
    function isDriver() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'driver';
    }
    /** Unassigned marketplace delivery orders visible to authenticated drivers. */
    function driverPoolOrderReadable(d) {
      return isDriver()
        && noDriverAssignedYet(d)
        && d.get('deliveryType', '') == 'delivery'
        && (
          d.status == 'pending_driver'
          || d.status == 'awaiting_driver'
        );
    }
    function canAccessMarketplaceDeliveryOrder(d) {
      return isAdmin()
        || (
          primaryUidFromOrder(d) is string
          && primaryUidFromOrder(d) == request.auth.uid
        )
        || (d.restaurantId is string && d.restaurantId == request.auth.uid)
        || driverAssignedToMarketplaceOrder(d)
        || isOrderMember(d)
        || driverPoolOrderReadable(d);
    }
    function isMarketplaceDeliveryOrderDoc(d) {
      return d.get('deliveryType', '') == 'delivery';
    }
    function marketplaceOrderPatchKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }
    function isRestaurantVendorActor(d) {
      return d.restaurantId is string && d.restaurantId == request.auth.uid;
    }
    function customerCancelStatusOk(before, after) {
      return after.status == 'cancelled'
        && before.status != 'delivered'
        && before.status != 'cancelled'
        && before.status != 'rejected';
    }
    function marketplaceCustomerPatchOk() {
      let before = resource.data;
      return primaryUidFromOrder(before) == request.auth.uid
        && marketplaceOrderPatchKeys().hasOnly(['status','updatedAt','cancelledAt','cancelledBy','notes','deliveryStatus'])
        && (
          request.resource.data.status == before.status
          || customerCancelStatusOk(before, request.resource.data)
        );
    }
    /** Checkout / client payment sheet updates (prefer tightening once all payment writes are server-side). */
    function marketplaceCustomerCheckoutPatchOk() {
      let before = resource.data;
      return primaryUidFromOrder(before) == request.auth.uid
        && marketplaceOrderPatchKeys().hasOnly([
          'status','paymentStatus','paymentIntentId','checkoutSessionId','stripePaymentIntentId',
          'updatedAt','paidAt','paymentFailedAt','estimatedDeliveryTime','deliveryStatus'
        ]);
    }
    function restaurantMustNotAssignDriver(before, after) {
      return !(
        (!(before.driverId is string && before.driverId.size() > 0))
        && after.driverId is string
        && after.driverId.size() > 0
      );
    }
    function marketplaceRestaurantPatchOk() {
      let before = resource.data;
      return isRestaurantVendorActor(before)
        && restaurantMustNotAssignDriver(before, request.resource.data)
        && marketplaceOrderPatchKeys().hasOnly([
          'status','acceptedAt','preparedAt','readyAt','estimatedDeliveryTime','estimatedPrepTime',
          'estimatedDeliveryMinutes','deliveryStatus','updatedAt','driverId','assignedDriverId',
          'driverName','driverPhone','driverVehicle','driver','notes','rejectionReason'
        ]);
    }
    function driverClaimPatchOk() {
      let before = resource.data;
      return requestUserIsDriver()
        && driverPoolOrderReadable(before)
        && (!(before.driverId is string && before.driverId.size() > 0))
        && request.resource.data.driverId == request.auth.uid
        && marketplaceOrderPatchKeys().hasOnly([
          'driverId','assignedDriverId','driverName','driverPhone','driverVehicle','driver',
          'status','deliveryStatus','acceptedAt','estimatedDeliveryTime','updatedAt','deliveryPin'
        ]);
    }
    function driverActivePatchOk() {
      let before = resource.data;
      return requestUserIsDriver()
        && before.driverId is string
        && before.driverId == request.auth.uid
        && marketplaceOrderPatchKeys().hasOnly([
          'driverLocation','status','deliveryStatus','pickedUpAt','deliveredAt',
          'estimatedDeliveryTime','updatedAt','driver','driverName','driverPhone','driverVehicle','acceptedAt'
        ]);
    }
    function marketplaceDriverPatchOk() {
      return driverClaimPatchOk() || driverActivePatchOk();
    }
    function marketplaceOrderActorPatchOk() {
      return marketplaceCustomerPatchOk()
        || marketplaceRestaurantPatchOk()
        || marketplaceDriverPatchOk();
    }

    /**
     * AI / assistant join discovery: readable subset of non-delivery `orders` docs.
     * Keep aligned with `JOIN_DISCOVERY_ORDER_STATUSES` in `constants/joinDiscovery.ts`.
     * Marketplace `deliveryType == delivery` stays on `canAccessMarketplaceDeliveryOrder` only.
     */
    function joinGrowthDiscoveryStatusOk(s) {
      return s == 'open'
        || s == 'active'
        || s == 'waiting'
        || s == 'matched'
        || s == 'pending'
        || s == 'full';
    }
    function isHalfOrderJoinDiscovery(d) {
      let users = d.get('users', []);
      let maxU = d.get('maxUsers', 2);
      return d.keys().hasAny(['cardId'])
        && d.cardId is string
        && d.cardId.size() > 0
        && users is list
        && usersAllStrings(users)
        && maxU is int
        && maxU >= 2
        && maxU <= 20
        && users.size() >= 1
        && users.size() < maxU
        && !(request.auth.uid in users)
        && d.status is string
        && joinGrowthDiscoveryStatusOk(d.status);
    }
    function isClassicSwipeJoinDiscovery(d) {
      let participants = d.get('participants', []);
      let maxP = d.get('maxPeople', 2);
      return (
          !d.keys().hasAny(['cardId'])
          || !(d.cardId is string)
          || d.cardId.size() == 0
        )
        && maxP is int
        && maxP >= 2
        && maxP <= 50
        && participants is list
        && participantsAllStrings(participants)
        && participants.size() >= 1
        && participants.size() < maxP
        && !(request.auth.uid in participants)
        && (
          !d.keys().hasAny(['usersAccepted'])
          || (
            d.usersAccepted is list
            && !(request.auth.uid in d.usersAccepted)
          )
        )
        && d.status is string
        && joinGrowthDiscoveryStatusOk(d.status);
    }
    function joinDiscoveryReadable(d) {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && !isMarketplaceDeliveryOrderDoc(d)
        && (isHalfOrderJoinDiscovery(d) || isClassicSwipeJoinDiscovery(d));
    }

    /**
     * Join-directory projection for AI / smart match queries (no phones, street addresses, or payment).
     * Only HTTPS restaurant/brand image URLs may appear (`syncPublicMatchableOrder` truncates and filters).
     * Writes: Admin SDK / Cloud Functions only (`syncPublicMatchableOrder`).
     * Any signed-in user may list/read (must stay above catch-all `/{document=**}` by path specificity).
     */
    match /public_matchable_orders/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    /** Per-user swipe gestures (like/pass) for food discovery analytics + matching. */
    match /swipes/{swipeId} {
      allow create: if isSignedIn()
        && !isCurrentUserRestricted()
        && request.resource.data.keys().hasOnly([
          'userId', 'orderId', 'foodId', 'restaurantId',
          'direction', 'liked', 'timestamp', 'createdAt'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.orderId is string
        && request.resource.data.orderId.size() > 0
        && request.resource.data.foodId is string
        && request.resource.data.restaurantId is string
        && request.resource.data.direction is string
        && (
          request.resource.data.direction == 'like'
          || request.resource.data.direction == 'pass'
        )
        && request.resource.data.liked is bool
        && request.resource.data.timestamp == request.time
        && request.resource.data.createdAt == request.time;
      allow read: if isSignedIn()
        && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update, delete: if false;
    }

    /** Shared checkout rooms after a match (server/client create when pairing completes). */
    match /sharedOrders/{sharedOrderId} {
      allow create: if isSignedIn()
        && !isCurrentUserRestricted()
        && request.resource.data.keys().hasOnly([
          'orderId', 'matchId', 'participantIds', 'foodTitle',
          'restaurantName', 'heroImageUri', 'splitPrice',
          'cartSubtotal', 'cartItems', 'status', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.orderId is string
        && request.resource.data.orderId.size() > 0
        && request.resource.data.participantIds is list
        && request.resource.data.participantIds.size() >= 2
        && request.resource.data.participantIds.size() <= 8
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.foodTitle is string
        && request.resource.data.foodTitle.size() > 0
        && request.resource.data.splitPrice is number
        && request.resource.data.splitPrice >= 0
        && request.resource.data.cartSubtotal is number
        && request.resource.data.cartSubtotal >= 0
        && request.resource.data.cartItems is list
        && request.resource.data.status == 'open'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow read: if isSignedIn()
        && (
          isAdmin()
          || request.auth.uid in resource.data.get('participantIds', [])
        );
      allow update: if isAdmin()
        || (
          isSignedIn()
          && !isCurrentUserRestricted()
          && request.auth.uid in resource.data.get('participantIds', [])
          && request.resource.data.participantIds == resource.data.participantIds
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'cartItems', 'cartSubtotal', 'checkoutStartedBy', 'updatedAt'
          ])
          && request.resource.data.updatedAt == request.time
        );
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Published baseline: owner / restaurant / driver may read their orders.
      allow read: if ordersReadByParticipant();
      // Marketplace checkout: auth uid must match payload userId + field guards.
      allow create: if isValidMarketplaceOrderCreate();
      // HalfOrder / legacy order creates (separate schema; no userId required).
      allow create: if isSignedIn()
        && !isCurrentUserRestricted()
        && canCreateOrderBySafetyLimits()
        && (
          isValidHalfOrderCreate()
          || isValidOrderCreate()
          || (
            request.resource.data.creatorId == request.auth.uid
            && request.resource.data.participants is list
          )
          || (
            request.resource.data.users is list
            && request.auth.uid in request.resource.data.users
          )
        );
      // Extended read (admin, driver pool, HalfOrder discovery, members).
      allow read: if isSignedIn()
        && (isAdmin() || !isCurrentUserRestricted())
        && (
          canAccessMarketplaceDeliveryOrder(resource.data)
          || joinDiscoveryReadable(resource.data)
        );
      allow update: if isSignedIn()
        && (
          isAdmin()
          || isSwipeAcceptUpdate()
          || isParticipantsJoinUpdate()
          || isParticipantsJoinWithExtrasUpdate()
          || isHalfOrderParticipantIncrementalJoin()
          || isHalfOrderParticipantBootstrapJoin()
          || isJoinedAtMapBackfillUpdate()
          || isParticipantsLeaveUpdate()
          || isOrderTypingUpdate()
          || isCreatorOnlyNonJoinUpdate()
          || isMarkOrderExpiredUpdate()
          || isHalfOrderCancelUpdate()
          || isHalfOrderMarkActiveUpdate()
          || isHalfOrderCompleteUpdate()
          || (
            !isCurrentUserRestricted()
            && canAccessMarketplaceDeliveryOrder(resource.data)
            && (
              !isMarketplaceDeliveryOrderDoc(resource.data)
              || marketplaceOrderActorPatchOk()
            )
          )
        );
      allow delete: if isAdmin()
        || (
          isSignedIn()
          && primaryUidFromOrder(resource.data) == request.auth.uid
        );

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && (
            isAdmin()
            || (
              !isCurrentUserRestricted()
              && canAccessMarketplaceDeliveryOrder(
                get(/databases/$(database)/documents/orders/$(orderId)).data
              )
            )
          );
        allow create: if isSignedIn()
          && !isCurrentUserRestricted()
          && (
            isAdmin()
            || canAccessMarketplaceDeliveryOrder(
              get(/databases/$(database)/documents/orders/$(orderId)).data
            )
          )
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 600
          && request.resource.data.createdAt == request.time
          && (
            !request.resource.data.keys().hasAny(['chatType'])
            || (
              request.resource.data.chatType == 'customer_driver'
              || request.resource.data.chatType == 'restaurant_driver'
              || request.resource.data.chatType == 'support'
            )
          )
          && (
            !request.resource.data.keys().hasAny(['senderRole'])
            || (
              request.resource.data.senderRole is string
              && request.resource.data.senderRole.size() > 0
              && request.resource.data.senderRole.size() <= 24
            )
          );
        allow update, delete: if false;
      }
    }
    match /food_cards/{cardId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isValidFoodCardOrderIdLink(cardId) || isValidFoodCardJoinUpdate();
    }
    match /foodTemplates/{templateId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.members is list
        && request.resource.data.members.size() == 1
        && request.resource.data.members[0] == request.auth.uid
        && request.resource.data.foodType is string
        && request.resource.data.maxSize == 4
        && request.resource.data.status == 'waiting'
        && request.resource.data.anchorLocation is map;
      allow update: if request.auth != null
        && (
          (resource.data.members is list && request.auth.uid in resource.data.members)
          || (
            resource.data.members is list
            && request.resource.data.members is list
            && request.resource.data.members.size() == resource.data.members.size() + 1
            && request.auth.uid in request.resource.data.members
            && resource.data.members.size() < 4
          )
        );
      allow delete: if request.auth != null && resource.data.members is list && request.auth.uid in resource.data.members;
    }
    match /carts/{cartId} {
      allow read, write: if request.auth != null;
    }
    match /payments/{paymentId} {
      allow read, write: if request.auth != null;
    }
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create, update, delete: if isAdmin()
        || (
          request.auth != null
          && request.auth.uid == restaurantId
          && requestUserIsRestaurant()
        );
      match /orders/{orderId} {
        allow read, write: if isAdmin()
          || (
            request.auth != null
            && request.auth.uid == restaurantId
            && requestUserIsRestaurant()
          );
      }
      match /{sub=**} {
        allow read: if true;
        allow write: if isAdmin()
          || (
            request.auth != null
            && request.auth.uid == restaurantId
            && requestUserIsRestaurant()
          );
      }
    }
    match /menuItems/{itemId} {
      allow read: if true;
      allow create, update, delete: if isAdmin()
        || (request.auth != null && request.resource.data.restaurantId is string && request.resource.data.restaurantId == request.auth.uid)
        || (request.auth != null && resource.data.restaurantId is string && resource.data.restaurantId == request.auth.uid);
    }
    match /drivers/{driverId} {
      allow read: if isAdmin()
        || (request.auth != null && request.auth.uid == driverId && requestUserIsDriver())
        || (request.auth != null && requestUserIsDriver());
      allow create, update, delete: if request.auth != null
        && request.auth.uid == driverId
        && requestUserIsDriver();
    }
    match /app_sessions/{sessionId} {
      allow read, write: if request.auth != null;
    }
    match /notification_opens/{docId} {
      allow read, write: if request.auth != null;
    }
    match /live_locations/{orderId} {
      function liveLocOrderData() {
        return get(/databases/$(database)/documents/orders/$(orderId)).data;
      }
      allow read: if isSignedIn()
        && !isCurrentUserRestricted()
        && canAccessMarketplaceDeliveryOrder(liveLocOrderData());
      allow create, update: if isSignedIn()
        && !isCurrentUserRestricted()
        && requestUserIsDriver()
        && canAccessMarketplaceDeliveryOrder(liveLocOrderData())
        && liveLocOrderData().driverId == request.auth.uid
        && request.resource.data.orderId == orderId
        && request.resource.data.driverId == request.auth.uid
        && request.resource.data.lat is number
        && request.resource.data.lng is number
        && request.resource.data.keys().hasOnly(['orderId','driverId','lat','lng','heading','speed','updatedAt']);
      allow delete: if false;
    }
    /**
     * Optional driver dispatch queue documents (HalfOrder / OurFood).
     * Drivers and admins only; aligns with client delivery-layer expectations.
     */
    match /deliveryQueue/{docId} {
      allow read, write: if isSignedIn()
        && !isCurrentUserRestricted()
        && (isAdmin() || requestUserIsDriver());
    }
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
