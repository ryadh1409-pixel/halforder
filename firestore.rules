      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }
    function usersRoleSelfAssignOk() {
      let before = resource.data.get('role', 'user');
      let after = request.resource.data.get('role', 'user');
      return (before == 'user' || before == 'customer' || before == '')
        && (after == 'restaurant' || after == 'driver');
    }
