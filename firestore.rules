        && request.resource.data.participants == resource.data.participants
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.reads is map
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['reads'])
        && (
          !resource.data.keys().hasAny(['reads'])
          || (resource.data.reads is map && request.resource.data.reads.keys().hasAll(resource.data.reads.keys()))
        );
    }
    function isChatMessageStatusUpdate(chatId) {
      return isSignedIn()
        && isChatDocMember(chatId)
        && resource.data.senderId is string
        && resource.data.senderId != request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['deliveredAt', 'readAt'])
        && (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(['deliveredAt'])
