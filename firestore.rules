        && request.resource.data.status == 'open'
        && request.resource.data.createdAt == request.time
        && request.resource.data.userId == request.auth.uid
        && (!request.resource.data.keys().hasAny(['description']) || request.resource.data.description == null || request.resource.data.description is string)
        && (!request.resource.data.keys().hasAny(['messageId']) || request.resource.data.messageId == null || request.resource.data.messageId is string);
    }
    function isValidReportCreate() {
      return isSignedIn()
        && !isCurrentUserRestricted()
        && (isValidUgcReportCreate() || isValidFoodShareReportCreate());
    }
    function isValidModerationAuditCreate() {
      return isSignedIn()
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.action is string
        && request.resource.data.source == 'food_share'
        && request.resource.data.createdAt == request.time;
    }
    match /reports/{reportId} {
      allow create: if isValidReportCreate();
      allow read, update, delete: if isAdmin();
    }
    match /moderationAuditLog/{eventId} {
      allow create: if isValidModerationAuditCreate() || isAdmin();
      allow read: if isAdmin();
      allow update, delete: if false;
    }
    match /support_chats/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow write: if false;
    }
    match /support_chats/{userId}/messages/{messageId} {
      allow read, write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
    }
    match /ratings/{ratingId} {
      allow create: if request.auth != null
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.orderId is string
        && request.resource.data.toUserId is string
        && request.resource.data.comment is string
        && request.resource.data.createdAt != null
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }
    match /feedback/{feedbackId} {
      allow create: if request.auth != null
        && !isCurrentUserRestricted()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userName is string
        && request.resource.data.message is string
        && (request.resource.data.sentiment == 'positive' || request.resource.data.sentiment == 'negative' || request.resource.data.sentiment == 'neutral')
        && request.resource.data.source == 'assistant_chat'
        && request.resource.data.createdAt == request.time
        && (!request.resource.data.keys().hasAny(['userEmail']) || request.resource.data.userEmail is string);
