rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn()
        && (
          (
            request.auth.token.email is string
            && (
              request.auth.token.email.lower() == 'ryadh1409@gmail.com'
              || request.auth.token.email.lower() == 'admin@ourfood.com'
              || request.auth.token.email.lower() == 'support@halforder.app'
            )
          )
          || request.auth.uid == 'KT3LfXRsVgaH4LfRTQaexvj3CRn1'
          || request.auth.uid == 'Gjj6x4OU4OQmsnplollo9PLLpxt2'
          || (
            firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
            && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin'
          )
          || (
            firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid))
            && firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.get('active', false) == true
          )
        );
    }
    function isValidImageUpload() {
      return request.resource.size < 12 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Profile avatar — public read, owner-only write (`profiles/{uid}.jpg`). */
    match /profiles/{fileName} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && isValidImageUpload()
        && fileName == request.auth.uid + '.jpg';
      allow delete: if isSignedIn() && fileName == request.auth.uid + '.jpg';
    }

    /** Per-user private uploads (`users/{uid}/...`). */
    match /users/{userId}/{allPaths=**} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidImageUpload();
      allow delete: if isOwner(userId) || isAdmin();
    }

    /** Driver-owned assets (`drivers/{uid}/...`). */
    match /drivers/{driverId}/{allPaths=**} {
      allow read: if isOwner(driverId) || isAdmin();
      allow create, update: if isOwner(driverId) && isValidImageUpload();
      allow delete: if isOwner(driverId) || isAdmin();
    }

    /** Restaurant-owned assets (`restaurants/{uid}/...`). */
    match /restaurants/{restaurantId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if isOwner(restaurantId) && isValidImageUpload();
      allow delete: if isOwner(restaurantId) || isAdmin();
    }

    /** Legacy generic uploads — namespaced by uid folder. */
    match /uploads/{userId}/{allPaths=**} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidImageUpload();
      allow delete: if isOwner(userId) || isAdmin();
    }

    /** Admin catalog images (`services/uploadImage.ts` → foodTemplates/). */
    match /foodTemplates/{allPaths=**} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() && isValidImageUpload();
    }

    /** Admin Home promotional banners. */
    match /homeBanners/{allPaths=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidImageUpload();
    }

    /** Admin onboarding slide images. */
    match /onboarding/{allPaths=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidImageUpload();
    }

    /** Deny all other paths by default. */
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
