rules_version = '2';
// DEBUG ONLY: open read/write for any signed-in user. Emulator / disposable project only.
// Restore production `firestore.rules` before any real deploy.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
