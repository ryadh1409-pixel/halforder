PORT=3000
STRIPE_SECRET_KEY=sk_test_...
STRIPE_REFRESH_URL=https://example.com/reauth
STRIPE_RETURN_URL=https://example.com/success
# Option A: copy your Firebase service account JSON to backend/serviceAccountKey.json (gitignored)
# Option B: path to JSON (relative to this backend folder)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
# Option C: inline JSON (single line)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Expo (repo root .env): use your laptop’s LAN IP (same Wi‑Fi as the phone).
# Avoid localhost for physical devices — use e.g. http://192.168.1.10:3000
# EXPO_PUBLIC_STRIPE_API_URL=http://192.168.1.10:3000
# iOS Simulator on same Mac: http://127.0.0.1:3000 is OK
# Android emulator: http://10.0.2.2:3000
