            },
            {
              "scheme": "https",
              "host": "halforder.app",
              "pathPrefix": "/terms"
            },
            {
              "scheme": "https",
              "host": "halforder.app",
              "pathPrefix": "/privacy"
            },
            {
              "scheme": "https",
              "host": "halforder.app",
              "pathPrefix": "/safety-community-guidelines"
            },
            {
              "scheme": "https",
              "host": "halforder.app",
              "pathPrefix": "/subscribe"
            },
            {
              "scheme": "https",
              "host": "www.halforder.app",
              "pathPrefix": "/order"
            },
            {
              "scheme": "https",
              "host": "www.halforder.app",
              "pathPrefix": "/join"
            },
            {
              "scheme": "https",
              "host": "www.halforder.app",
              "pathPrefix": "/group"
            },
            {
              "scheme": "https",
              "host": "www.halforder.app",
              "pathPrefix": "/terms"
            },
            {
              "scheme": "https",
              "host": "www.halforder.app",
              "pathPrefix": "/privacy"
            },
            {
              "scheme": "https",
              "host": "www.halforder.app",
              "pathPrefix": "/safety-community-guidelines"
            },
            {
              "scheme": "https",
              "host": "www.halforder.app",
              "pathPrefix": "/subscribe"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/app-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.ourfoodclean",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-notifications",
        {
          "sounds": [],
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "HalfOrder needs your precise location to set your delivery address and show nearby restaurants."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "We need access to your photos so you can upload a profile picture.",
          "cameraPermission": "We need access to your camera to take a profile photo."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.halforder.app",
          "enableGooglePay": true
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9b7ffbaf-659d-493c-a1bd-a695e2c2982c"
      },
      "iosAppStoreId": ""
    },
    "owner": "thamer1989",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9b7ffbaf-659d-493c-a1bd-a695e2c2982c"
    }
  }
