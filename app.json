{
  "expo": {
    "name": "HalfOrder",
    "slug": "ourfood-clean",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "halforder",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.halforder.app",
      "buildNumber": "3",
      "entitlements": {
        "com.apple.developer.in-app-payments": [
          "merchant.com.halforder.app"
        ]
      },
      "associatedDomains": [
        "applinks:halforder.app",
        "applinks:www.halforder.app"
      ],
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "HalfOrder needs your precise location to set your delivery address and show nearby restaurants.",
        "NSPhotoLibraryUsageDescription": "We need access to your photos so you can upload a profile picture.",
        "NSPhotoLibraryAddUsageDescription": "HalfOrder may save images you share only when you choose to save them.",
        "NSCameraUsageDescription": "We need access to your camera to take a profile photo.",
        "NSMicrophoneUsageDescription": "HalfOrder uses the microphone so you can shout “Hi Emo” to wake Emo AI.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "halforder"
            ],
            "CFBundleURLName": "HalfOrder Deep Link"
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.1087129301998-fpbmk5onqteqmgjsf91hq7cl7knobukf"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "halforder"
            ],
            "CFBundleURLName": "HalfOrder Deep Link"
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.1087129301998-fpbmk5onqteqmgjsf91hq7cl7knobukf"
            ]
          }
        ]
      }
    },
    "android": {
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "halforder.app",
              "pathPrefix": "/order"
            },
            {
              "scheme": "https",
              "host": "halforder.app",
              "pathPrefix": "/join"
            },
            {
              "scheme": "https",
              "host": "halforder.app",
