# Copy to `.env` in the project root and set your keys (never commit `.env`).
OPENAI_API_KEY=your_key_here

# Google Maps — iOS native maps (react-native-maps + Maps SDK for iOS)
# Enable "Maps SDK for iOS" and "Places API" in Google Cloud Console.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Legacy server-side / Places scripts (optional)
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Stripe (publishable only — never put the secret key in the client bundle)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Web Stripe Checkout redirect base URL (e.g. http://localhost:8081 or http://localhost:8085)
EXPO_PUBLIC_APP_URL=http://localhost:8081

# Optional legacy Stripe Connect Express URL (Stripe HTTP is disabled in app — Connect uses Firebase callables).

# Callable region — must match `firebase deploy`
# EXPO_PUBLIC_FUNCTIONS_REGION=us-central1
