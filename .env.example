# Copy to `.env` in the project root and set your keys (never commit `.env`).
OPENAI_API_KEY=your_key_here

# Google Maps (client) — required for Places, Geocoding, and native map tiles.
# In Google Cloud Console (same project as Firebase):
#   1. Enable: Geocoding API, Places API, Maps SDK for iOS, Maps SDK for Android
#   2. Create an API key (starts with AIza…)
#   3. Application restrictions (testing): None — or iOS bundle com.halforder.app + Android package
#   4. API restrictions: restrict key to the four APIs above
# After changing .env: npx expo start -c
# EAS builds: set EXPO_PUBLIC_GOOGLE_MAPS_API_KEY in EAS Secrets or eas.json env
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Legacy alias (optional)
EXPO_PUBLIC_GOOGLE_API_KEY=

# Server-side scripts only (optional — not used by Expo client)
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Stripe (publishable only — never put the secret key / sk_* in the client bundle)
# Production / EAS production builds must use pk_live_...
# Local test builds may use pk_test_... — never mix with a live secret on Functions.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Web Stripe Checkout redirect base URL (e.g. http://localhost:8081 or http://localhost:8085)
EXPO_PUBLIC_APP_URL=http://localhost:8081

# Callable region — must match `firebase deploy`
# EXPO_PUBLIC_FUNCTIONS_REGION=us-central1
